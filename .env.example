# Datenbank
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=dein_passwort
DB_NAME=footballai
# Alternativ: vollständige Verbindungs-URL statt der einzelnen DB_*-Variablen
DATABASE_URL=mysql+pymysql://root:dein_passwort@localhost:3306/footballai

# APIs
API_FOOTBALL_KEY=dein_api_football_key

# LLM (eines davon)
GEMINI_API_KEY=dein_gemini_key
ANTHROPIC_API_KEY=dein_anthropic_key   # alternativ

# LLM-Provider: gemini | claude | ollama
LLM_PROVIDER=gemini

# Dashboard (optional, aktiviert Passwortschutz)
DASHBOARD_PASSWORD=dein_dashboard_passwort

# Telegram-Bot (optional)
TELEGRAM_BOT_TOKEN=dein_bot_token        # von @BotFather
TELEGRAM_CHAT_ID=deine_chat_id           # eigene Chat-ID (Owner)
ALLOWED_CHAT_IDS=123456,789012           # optionale Whitelist, sonst nur Owner
TIMEZONE=Europe/Zurich
